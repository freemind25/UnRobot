name: CI/CD Simple Workflow

# Déclencheurs : définit quand le workflow s'exécute
on:
  push:
    branches: [ "main" ]
  pull_request:
    branches: [ "main" ]

jobs:
  build-and-test:
    runs-on: ubuntu-latest

    steps:
    # 1. Récupérer le code source du dépôt
    - name: Checkout code
      uses: actions/checkout@v4

    # 2. Configurer l'environnement (exemple avec Node.js)
    - name: Set up Node.js
      uses: actions/setup-node@v4
      with:
        node-version: '20'
        cache: 'pnpm'

    # 3. Installer les dépendances
    - name: Install dependencies
      run: pnpm install

    # 4. Exécuter les tests
    - name: Run tests
      run: pnpm test

    # 5. Exemple d'utilisation de la CLI GitHub (gh)
    # Cette étape crée un commentaire automatique sur la PR si les tests réussissent
    - name: Comment on PR
      if: github.event_name == 'pull_request'
      env:
        GH_TOKEN: ${{ secrets.GITHUB_TOKEN }}
      run: |
        gh pr comment ${{ github.event.pull_request.number }} --body "✅ Les tests CI sont passés avec succès sur cette branche !"
